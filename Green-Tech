    <title>Green Tech Investing | Brandon Kirby Advisory</title>
    <style>
        :root {
            --primary: #0f2b46;
            --secondary: #1d4ed8;
            --text-dark: #1f2937;
            --text-light: #f9fafb;
            --bg-light: #f3f4f6;
            --accent: #059669;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            color: var(--text-dark);
            line-height: 1.6;
            background-color: #ffffff;
        }

        /* Navigation */
        nav {
            background-color: var(--primary);
            color: var(--text-light);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        nav .logo {
            font-size: 1.5rem;
            font-weight: bold;
            letter-spacing: 1px;
        }

        nav ul {
            display: flex;
            list-style: none;
        }

        nav ul li {
            margin-left: 2rem;
        }

        nav ul li a {
            color: var(--text-light);
            text-decoration: none;
            font-weight: 500;
            transition: color 0.3s;
        }

        nav ul li a:hover {
            color: #93c5fd;
        }

        /* Hero Section - Using a slightly distinct tone overlay for differentiation */
        .hero {
            background: linear-gradient(rgba(15, 43, 70, 0.95), rgba(5, 150, 105, 0.4)), url('https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=1950&q=80') no-repeat center center/cover;
            color: var(--text-light);
            padding: 6rem 2rem;
            text-align: center;
        }

        .hero h1 {
            font-size: 2.75rem;
            margin-bottom: 1rem;
        }

        .hero p {
            font-size: 1.2rem;
            max-width: 800px;
            margin: 0 auto;
        }

        /* Content Structure */
        section {
            padding: 4rem 2rem;
            max-width: 900px;
            margin: 0 auto;
        }

        .strategy-block {
            margin-bottom: 3rem;
        }

        .strategy-block h2 {
            color: var(--primary);
            font-size: 1.8rem;
            margin-bottom: 1rem;
            border-bottom: 2px solid var(--accent);
            padding-bottom: 0.5rem;
        }

        .strategy-block p {
            font-size: 1.1rem;
            color: #374151;
            margin-bottom: 1.5rem;
        }

        /* Bullet List styling */
        .detail-list {
            list-style-type: square;
            padding-left: 1.5rem;
            margin-bottom: 2rem;
        }

        .detail-list li {
            margin-bottom: 0.75rem;
            font-size: 1.05rem;
        }

        .detail-list strong {
            color: var(--accent);
        }

        .btn-back {
            display: inline-block;
            background-color: var(--accent);
            color: var(--text-light);
            text-decoration: none;
            padding: 0.75rem 1.5rem;
            border-radius: 4px;
            font-weight: 500;
            transition: background-color 0.3s;
            margin-top: 1rem;
        }

        .btn-back:hover {
            background-color: #047857;
        }

        footer {
            background-color: #0b1f33;
            color: #9ca3af;
            text-align: center;
            padding: 1.5rem;
            font-size: 0.85rem;
            margin-top: 4rem;
        }
    </style>
</head>
